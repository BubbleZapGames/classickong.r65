// ============================================================================
// Classic Kong Complete - Kong AI and Animation
// ============================================================================
// Handles Kong's behavior, barrel throwing, and princess display
// ============================================================================

#[bank(0)]

// ============================================================================
// CONSTANTS - Kong States
// ============================================================================

const KONG_STATE_STAND: u8 = 0;
const KONG_STATE_TAKE: u8 = 1;
const KONG_STATE_MIDDLE: u8 = 2;
const KONG_STATE_DROP: u8 = 3;
const KONG_STATE_WAIT: u8 = 4;


// ============================================================================
// KONG STATE VARIABLES
// ============================================================================

#[lowram]
static mut kong_x: u8;

#[lowram]
static mut kong_y: i16;

#[lowram]
static mut kong_frame_cnt: u8;

#[lowram]
static mut kong_state: u8;

#[lowram]
static mut kong_delay: u8;

#[lowram]
static mut kong_throw_wild_barrel: u8;

#[lowram]
static mut kong_wild_barrel_type: u8;

#[lowram]
static mut kong_start: u8;

// Pointer to current animation frame data
#[lowram]
static mut kong_frame_idx: u8;

#[lowram]
static mut kong_frame_bank: u8;


// ============================================================================
// PRINCESS STATE VARIABLES
// ============================================================================

#[lowram]
static mut princess_x: u8;

#[lowram]
// Signed so the climb-off-screen path in cutscene_next_level can let
// princess_y go negative (matches C original's `static int princess_y`).
static mut princess_y: i16;


// ============================================================================
// LADDER VARIABLES (Level 2 retractable ladders + intro cutscene falling)
// ============================================================================

const LADDERS_MAX: u8 = 22;

#[ram]
static mut ladders_x: [u8; 22];

#[ram]
static mut ladders_y: [u8; 22];

#[ram]
static mut ladders_dir: [u8; 22];

#[ram]
static mut ladders_cnt: [u8; 22];

#[ram]
static mut ladders_delay: [u8; 22];


// ============================================================================
// DIFFICULTY VARIABLES
// ============================================================================

#[lowram]
static mut game_level_difficulty_count: u16;

#[lowram]
static mut game_bounce_delay: u16;

#[lowram]
static mut conveyor_cnt_middle: u8;

#[lowram]
static mut game_belts_update: u8;

#[ram]
static mut conveyor_cnt: [u16; 3];


// ============================================================================
// FIREBALL SPAWN POINTS (Level 4)
// ============================================================================

#[lowram]
static mut fireball_spawn_all: u8;

#[ram]
static mut fireball_spawn_x: [u8; 8];

#[ram]
static mut fireball_spawn_y: [u8; 8];


