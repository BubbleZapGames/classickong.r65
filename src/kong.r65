];

// Kong falling sprites (level-end cutscene). y-offsets are signed; the u16
// storage is reinterpreted as i16 by game_show_kong's frame[idx+1] as i16.
// Match game.c:622-644.
static kong_falling1: [u16; 12] = [
    0xFFF8 /* -8 */,  8, KONG_TILE + 0x80 | KONG_ATR,
                  8,  8, KONG_TILE + 0x82 | KONG_ATR,
                 24,  8, KONG_TILE + 0x84 | KONG_ATR,
                  8, 24, KONG_TILE + 0x8A | KONG_ATR
];

static kong_falling2: [u16; 12] = [
    0xFFF8 /* -8 */,  8, KONG_TILE + 0x84 | KONG_ATR | SPR_HFLIP,
                  8,  8, KONG_TILE + 0x86 | KONG_ATR,
                 24,  8, KONG_TILE + 0x80 | KONG_ATR | SPR_HFLIP,
                  8, 24, KONG_TILE + 0x8E | KONG_ATR
];

// Fell sprite has only 3 visible sprites; the C original terminates with 128
// after entry 3. Pad the 4th entry with a y-offset that puts it off-screen
// (game_show_kong hides any sprite whose final y is >= 240).
static kong_fell: [u16; 12] = [
    0xFFF8 /* -8 */,  8, KONG_TILE + 0x88 | KONG_ATR,
                  8,  8, KONG_TILE + 0x8C | KONG_ATR,
                 24,  8, KONG_TILE + 0x88 | KONG_ATR | SPR_HFLIP,
                  0, 240, 0  // hidden — pushes ky+offset off-screen
];


// ============================================================================
// ANIMATION SEQUENCE INDICES
// For left-right animation: face1, face2L, face3L, face4L, face3L, face2L,
//                          face1, face2R, face3R, face4R, face3R, face2R, face1
// ============================================================================

const KONG_ANIM_FACE1: u8 = 0;
const KONG_ANIM_FACE2_BOTH: u8 = 1;
const KONG_ANIM_FACE3_BOTH: u8 = 2;
const KONG_ANIM_FACE4_BOTH: u8 = 3;
const KONG_ANIM_FACE2_LEFT: u8 = 4;
const KONG_ANIM_FACE3_LEFT: u8 = 5;
const KONG_ANIM_FACE4_LEFT: u8 = 6;
const KONG_ANIM_FACE2_RIGHT: u8 = 7;
const KONG_ANIM_FACE3_RIGHT: u8 = 8;
const KONG_ANIM_FACE4_RIGHT: u8 = 9;
const KONG_ANIM_SIDE_LEFT: u8 = 10;
const KONG_ANIM_SIDE_RIGHT: u8 = 11;
const KONG_ANIM_THROW: u8 = 12;
const KONG_ANIM_LAUGH: u8 = 13;
const KONG_ANIM_CLIMB1_RIGHT: u8 = 14;
const KONG_ANIM_CLIMB2_RIGHT: u8 = 15;
const KONG_ANIM_CLIMB1_LEFT: u8 = 16;
const KONG_ANIM_CLIMB2_LEFT: u8 = 17;
const KONG_ANIM_FALLING1: u8 = 18;
const KONG_ANIM_FALLING2: u8 = 19;
const KONG_ANIM_FELL: u8 = 20;

// Left-right animation sequence for level 1
static kong_anim_leftright: [u8; 14] = [
    KONG_ANIM_FACE1,
    KONG_ANIM_FACE2_LEFT,
    KONG_ANIM_FACE3_LEFT,
    KONG_ANIM_FACE4_LEFT,
    KONG_ANIM_FACE3_LEFT,
    KONG_ANIM_FACE2_LEFT,
    KONG_ANIM_FACE1,
    KONG_ANIM_FACE2_RIGHT,
    KONG_ANIM_FACE3_RIGHT,
    KONG_ANIM_FACE4_RIGHT,
    KONG_ANIM_FACE3_RIGHT,
    KONG_ANIM_FACE2_RIGHT,
    KONG_ANIM_FACE1,
    KONG_ANIM_FACE1
];

// Both arms animation sequence for levels 2-4
static kong_anim_both: [u8; 6] = [
    KONG_ANIM_FACE1,
    KONG_ANIM_FACE2_BOTH,
    KONG_ANIM_FACE3_BOTH,
    KONG_ANIM_FACE4_BOTH,
    KONG_ANIM_FACE3_BOTH,
    KONG_ANIM_FACE1
];


// ============================================================================
// FUNCTION: Draw Kong at Position
// ============================================================================

far fn game_show_kong(oam_off: u16, kx: u8, ky: i16) {
    let anim_idx: u8 = kong_frame_idx;
    let mut frame: far *u16;

    // Select frame data based on animation index
    if anim_idx == KONG_ANIM_FACE1 {
        frame = &kong_face1 as far *u16;
    } else if anim_idx == KONG_ANIM_FACE2_BOTH {
        frame = &kong_face2_both as far *u16;
    } else if anim_idx == KONG_ANIM_FACE3_BOTH {
        frame = &kong_face3_both as far *u16;
    } else if anim_idx == KONG_ANIM_FACE4_BOTH {
        frame = &kong_face4_both as far *u16;
    } else if anim_idx == KONG_ANIM_FACE2_LEFT {
        frame = &kong_face2_left as far *u16;
    } else if anim_idx == KONG_ANIM_FACE3_LEFT {
        frame = &kong_face3_left as far *u16;
    } else if anim_idx == KONG_ANIM_FACE4_LEFT {
        frame = &kong_face4_left as far *u16;
    } else if anim_idx == KONG_ANIM_FACE2_RIGHT {
        frame = &kong_face2_right as far *u16;
    } else if anim_idx == KONG_ANIM_FACE3_RIGHT {
        frame = &kong_face3_right as far *u16;
    } else if anim_idx == KONG_ANIM_FACE4_RIGHT {
        frame = &kong_face4_right as far *u16;
    } else if anim_idx == KONG_ANIM_SIDE_LEFT {
        frame = &kong_side_left as far *u16;
    } else if anim_idx == KONG_ANIM_SIDE_RIGHT {
        frame = &kong_side_right as far *u16;
    } else if anim_idx == KONG_ANIM_THROW {
        frame = &kong_throw as far *u16;
    } else if anim_idx == KONG_ANIM_LAUGH {
        frame = &kong_laugh as far *u16;
    } else if anim_idx == KONG_ANIM_CLIMB1_RIGHT {
        frame = &kong_climb1_right as far *u16;
    } else if anim_idx == KONG_ANIM_CLIMB2_RIGHT {
        frame = &kong_climb2_right as far *u16;
    } else if anim_idx == KONG_ANIM_CLIMB1_LEFT {
        frame = &kong_climb1_left as far *u16;
    } else if anim_idx == KONG_ANIM_CLIMB2_LEFT {
        frame = &kong_climb2_left as far *u16;
    } else if anim_idx == KONG_ANIM_FALLING1 {
        frame = &kong_falling1 as far *u16;
    } else if anim_idx == KONG_ANIM_FALLING2 {
        frame = &kong_falling2 as far *u16;
    } else if anim_idx == KONG_ANIM_FELL {
        frame = &kong_fell as far *u16;
    } else {
        frame = &kong_face1 as far *u16;
    }

    // Draw 4 sprites for Kong
    let mut i: u8 = 0;
    let mut off: u16 = oam_off;

    loop {
        let idx: u16 = mul8(i, 3);
        let sx: i16 = (kx as i16) + (frame[idx] as i16);
        let sy: i16 = ky + (frame[idx + 1] as i16);
        let tile: u16 = frame[idx + 2];

        // Mirrors C original (game_loop.h:223-237):
        //   if (ky >= 0)        { if (ky < 240) oam_spr1(...); else hide; }
        //   else /* ky < 0 */   { oam_spr(...); }
        // Negative ky must draw via oam_spr — that's how Kong climbs off
        // the top of the screen at the end of cutscene_next_level. oam_spr
        // also writes the extended-OAM X-high bit (necessary when the
        // wrapped y places the sprite where the SNES expects valid OAM).
        if sy >= 0 {
            if sy < 240 {
                oam_spr1(sx as u8, sy as u8, tile, off);
            } else {
                oam_spr1(0, 240, 0, off);
            }
        } else {
            oam_spr(sx as u16, sy as u8, tile, off);
        }

        off = off + 4;
        i++;
        if i >= 4 {
            break;
        }
    }

    // 5th sprite slot for barrel being held
    oam_spr1(0, 240, 0, off);
}


// ============================================================================
// FUNCTION: Draw Princess at Position
// ============================================================================

// Princess animation table: 3 frames x 2 sprites (top, bottom)
static princess_anim: [u16; 6] = [
    PRINCESS_TILE + 0x00 | PRINCESS_ATR,  // Frame 0 top
    PRINCESS_TILE + 0x02 | PRINCESS_ATR,  // Frame 0 bottom
    PRINCESS_TILE + 0x00 | PRINCESS_ATR,  // Frame 1 top
    PRINCESS_TILE + 0x0A | PRINCESS_ATR,  // Frame 1 bottom
    PRINCESS_TILE + 0x04 | PRINCESS_ATR,  // Frame 2 top
    PRINCESS_TILE + 0x06 | PRINCESS_ATR   // Frame 2 bottom
];

far fn game_show_princess(frame: u8) {
    let mut flip: u16 = 0;
    if game_flip != 0 {
        flip = SPR_HFLIP;
    }

    // Mirrors C original (game_loop.h:325-339):
    //   if (princess_y < 224) {
    //     i = frame << 1;
    //     if (princess_y >= 0) { oam_spr1(...); oam_spr1(...); }
    //     else                 { oam_spr(...);  oam_spr(...);  }
    //   }
    // The two branches differ only in oam_spr (writes X-high bit in
    // extended OAM) vs oam_spr1 (skips it).
    if princess_y < 224 {
        let i: u16 = (frame as u16) << 1;
        if princess_y >= 0 {
            oam_spr1(princess_x, princess_y as u8,
                     princess_anim[i] | flip, OAM_PRINCESS);
            oam_spr1(princess_x, (princess_y + 16) as u8,
                     princess_anim[i + 1] | flip, OAM_PRINCESS + 4);
        } else {
            oam_spr(princess_x as u16, princess_y as u8,
                    princess_anim[i] | flip, OAM_PRINCESS);
            oam_spr(princess_x as u16, (princess_y + 16) as u8,
                    princess_anim[i + 1] | flip, OAM_PRINCESS + 4);
        }
    }

    // Third sprite slot (unused, hide)
    oam_spr1(0, 240, 0, OAM_PRINCESS + 8);
}


// ============================================================================
// FUNCTION: Kong Stand Animation for Level 1
// Left-right swaying motion
// ============================================================================

far fn kong_stand_animation_level1() {
    kong_frame_idx = kong_anim_leftright[kong_frame_cnt];

    if (game_frame_cnt & 3) == 0 {
        kong_frame_cnt++;

        if kong_frame_cnt == 6 {
            sfx_play(SFX_CHN + 1, SFX_KONG_LEFT, kong_x + 16);
        }

        if kong_frame_cnt == 12 {
            sfx_play(SFX_CHN + 1, SFX_KONG_RIGHT, kong_x + 16);
            kong_frame_cnt = 0;
        }
    }
}


// ============================================================================
// FUNCTION: Kong Stand Animation for Levels 2-4
// Both arms pumping motion
// ============================================================================

far fn kong_stand_animation_level2() {
    kong_frame_idx = kong_anim_both[kong_frame_cnt];

    let mut frame: u8 = (game_frame_cnt & 255) as u8;

    // Reset at specific frames for synced animation
    if frame == 0 || frame == 35 || frame == 70 || frame == 90 {
        kong_frame_cnt = 0;
    }

    if (game_frame_cnt & 3) == 0 {
        kong_frame_cnt++;

        if kong_frame_cnt == 4 {
            sfx_play(SFX_CHN + 1, SFX_KONG_LEFT, kong_x + 16);
        }

        if kong_frame_cnt > 5 {
            kong_frame_cnt = 5;
        }
    }
}


// ============================================================================
// FUNCTION: Initialize Kong for Level Start
// ============================================================================

far fn kong_init() {
    kong_frame_cnt = 0;
    kong_state = KONG_STATE_STAND;
    kong_delay = 20;
    kong_throw_wild_barrel = TRUE;
    kong_frame_idx = KONG_ANIM_FACE1;
    kong_start = TRUE;
    kong_wild_barrel_type = mod8(game_loops, 3);

    // Initialize difficulty counters
    game_level_difficulty_count = 0;
    game_bounce_delay = 0;
}


// ============================================================================
// FUNCTION: Level 1 Kong Logic - Barrel Throwing
// ============================================================================

far fn kong_process_level1() -> u8 {
    let mut clear: u8 = 0;

    // Delay between throws decreases with game loops
    let mut delay: u16 = (game_loops as u16) * 8;
    if delay > 32 {
        delay = 32;
    }

    // Kong state machine for barrel throwing
    if kong_state == KONG_STATE_STAND {
        // Kong stands with idle animation
        if kong_delay != 0 {
            kong_delay--;
        }

        if kong_start == FALSE {
            kong_stand_animation_level1();
        }

        if kong_delay == 0 {
            let frame_check: u8 = kong_frame_cnt >> 2;
            if frame_check == 0 || frame_check == 6 {
                kong_start = FALSE;

                // Show barrel in Kong's hand
                let mut barrel_x: u8;
                if game_flip == 0 {
                    barrel_x = kong_x - 8;
                } else {
                    barrel_x = kong_x + 24;
                }
                oam_spr(barrel_x as u16, kong_y + 18, BARREL_TILE | BARREL_ATR, OAM_BARRELS + 16);

                kong_state = KONG_STATE_TAKE;
                if game_flip == 0 {
                    kong_frame_idx = KONG_ANIM_SIDE_LEFT;
                } else {
                    kong_frame_idx = KONG_ANIM_SIDE_RIGHT;
                }
                kong_delay = 14;
            }
        }
    } else if kong_state == KONG_STATE_TAKE {
        // Kong takes a barrel
        kong_delay--;

        if kong_delay == 0 {
            // Show barrel above head
            oam_spr((kong_x + 8) as u16, kong_y + 18, BARREL_TILE + 0x08 | BARREL_ATR, OAM_BARRELS + 16);

            kong_state = KONG_STATE_MIDDLE;
            kong_frame_idx = KONG_ANIM_FACE1;
            kong_delay = 12;
        }
    } else if kong_state == KONG_STATE_MIDDLE {
        // Kong turns to drop side
        kong_delay--;

        if kong_delay == 0 {
            if kong_throw_wild_barrel != 0 {
                // Throw wild barrel
                oam_spr(0, 240, 0, OAM_BARRELS + 16);

                enemy_add(ENEMY_WILD_BARREL_DOWN + kong_wild_barrel_type, kong_x + 8, (kong_y + 18) as u8, 0);

                kong_wild_barrel_type++;
                if kong_wild_barrel_type > 2 {
                    kong_wild_barrel_type = 0;
                }

                kong_throw_wild_barrel = FALSE;
                kong_state = KONG_STATE_WAIT;
                kong_frame_idx = KONG_ANIM_THROW;
                kong_delay = 68;
            } else {
                // Show barrel on drop side
                let mut barrel_x: u8;
                if game_flip == 0 {
                    barrel_x = kong_x + 24;
                } else {
                    barrel_x = kong_x - 8;
                }
                oam_spr(barrel_x as u16, kong_y + 18, BARREL_TILE | BARREL_ATR, OAM_BARRELS + 16);

                kong_state = KONG_STATE_DROP;
                if game_flip == 0 {
                    kong_frame_idx = KONG_ANIM_SIDE_RIGHT;
                } else {
                    kong_frame_idx = KONG_ANIM_SIDE_LEFT;
                }
                kong_delay = 14;
            }
        }
    } else if kong_state == KONG_STATE_DROP {
        // Delay after drop
        if kong_delay != 0 {
            kong_delay--;
        }

        if kong_delay == 0 && enemy_all < ENEMY_MAX {
            oam_spr(0, 240, 0, OAM_BARRELS + 16);

            let mut barrel_x: u8;
            let mut barrel_dx: i8;
            if game_flip == 0 {
                barrel_x = kong_x + 24;
                barrel_dx = 1;
            } else {
                barrel_x = kong_x - 8;
                barrel_dx = -1;
            }
            enemy_add(ENEMY_ROLLING_BARREL, barrel_x, (kong_y + 18) as u8, barrel_dx);

            sfx_play(SFX_CHN+1, SFX_BARREL_ROLL, kong_x+32);

            kong_state = KONG_STATE_WAIT;
            kong_delay = (68 - delay) as u8;
        }
    } else if kong_state == KONG_STATE_WAIT {
        // Wait after throw
        kong_delay--;

        if kong_delay == 0 {
            kong_state = KONG_STATE_STAND;
            kong_delay = (64 - delay) as u8;
            kong_frame_cnt = 0;
        }
    }

    // Draw Kong
    game_show_kong(OAM_KONG, kong_x, kong_y);

    // Increase difficulty every 20 seconds
    if game_level_difficulty_count < 1200 {
        game_level_difficulty_count++;
    } else {
        game_level_difficulty_count = 0;

        if game_level_difficulty < 5 {
            game_level_difficulty++;
        }

        kong_throw_wild_barrel = TRUE;
    }

    // Barrel fire collision check
    if barrel_fire != 0 {
        if barrel_fire_x + 16 >= player_x + 4 {
            if barrel_fire_x < player_x + 12 {
                if barrel_fire_y + 8 >= player_y + 4 {
                    if barrel_fire_y < player_y + 12 {
                        clear = LEVEL_LOSE;
                    }
                }
            }
        }
    }

    // Level ends when player reaches top platform
    if player_y == 16 {
        clear = LEVEL_CLEAR;
    }

    return clear;
}


// ============================================================================
// FUNCTION: Level 2 Kong Logic - Conveyor Belts
// ============================================================================

far fn kong_process_level2() -> u8 {
    let mut clear: u8 = 0;

    kong_stand_animation_level2();
    game_show_kong(OAM_KONG, kong_x, kong_y);
    game_show_ladders();

    // Cement pan spacing: 128 - game_loops*16, clipped to 48 minimum
    let mut val: u16 = 48;
    if game_loops < 5 {
        val = 128 - ((game_loops as u16) << 4);
    }

    // Moving ladders: state machine per ladder (0=down, 1=delay, 2=up, 3=delay)
    let mut li: u8 = 0;
    loop {
        if li >= 2 { break; }

        let dir: u8 = ladders_dir[li];
        if dir == 0 {
            // Moving down: 1 pixel every 8 frames, 16 pixels total
            if (game_frame_cnt & 7) == 0 {
                if ladders_cnt[li] < 16 {
                    ladders_y[li]++;
                    ladders_cnt[li]++;
                } else {
                    ladders_dir[li] = 1;
                    ladders_cnt[li] = 64 + ((rand() & 15) as u8) + (li << 4);
                }
            }
        } else if dir == 1 {
            // Delay before going up
            if ladders_cnt[li] != 0 {
                ladders_cnt[li]--;
            } else {
                ladders_dir[li] = 2;
            }
        } else if dir == 2 {
            // Moving up: 1 pixel every 4 frames, 16 pixels total
            if (game_frame_cnt & 3) == 0 {
                if ladders_cnt[li] < 16 {
                    ladders_y[li]--;
                    ladders_cnt[li]++;
                } else {
                    ladders_dir[li] = 3;
                    ladders_cnt[li] = 64 + ((rand() & 15) as u8) + (li << 4);
                }
            }
        } else {
            // dir == 3: Delay before going down
            if ladders_cnt[li] != 0 {
                ladders_cnt[li]--;
            } else {
                ladders_dir[li] = 0;
            }
        }

        // Push player down if standing above the ladder top (all dirs except 3)
        if ladders_dir[li] != 3 {
            let x: u8 = ladders_x[li];
            let y: u8 = ladders_y[li];
            if player_x >= x - 4 && player_x < x + 4 {
                if player_y >= 60 && player_y < y {
                    player_y++;
                }
            }
        }

        li++;
    }

    if (game_frame_cnt & 1) != 0 {
        // Move Kong on conveyor
        if conveyor_dir[0] != 0 {
            kong_x++;
        } else {
            kong_x--;
        }

        // Change conveyor directions at boundaries
        if kong_x < 26 || kong_x > 200 {
            conveyor_dir[0] = conveyor_dir[0] ^ 1;

            // Flip top conveyor visual (row 7, cols 3..28)
            let mut ni: u16 = 0;
            loop {
                if ni >= 26 { break; }
                nametable1[POS!(3, 7) + ni] = nametable1[POS!(3, 7) + ni] ^ 0xC;
                ni++;
            }

            if kong_x < 26 {
                conveyor_dir[2] = conveyor_dir[2] ^ 1;
                sfx_play(SFX_CHN+3, SFX_SWITCH, 128);

                // Flip bottom conveyor visual (row 22, all 32 cols)
                let mut nj: u16 = 0;
                loop {
                    if nj >= 32 { break; }
                    nametable1[POS!(0, 22) + nj] = nametable1[POS!(0, 22) + nj] ^ 0xC;
                    nj++;
                }
            }

            game_belts_update = TRUE;
        }

        // Middle conveyor occasionally flips direction once unlocked
        if conveyor_cnt_middle == 0 {
            if kong_x == 120 {
                if (rand() & 255) < 64 {
                    conveyor_dir[1] = conveyor_dir[1] ^ 1;
                    game_belts_update = TRUE;
                    sfx_play(SFX_CHN+3, SFX_SWITCH, 128);

                    let mut nk: u16 = 0;
                    loop {
                        if nk >= 15 { break; }
                        nametable1[POS!(0, 13) + nk] = nametable1[POS!(0, 13) + nk] ^ 0xC;
                        nametable1[POS!(17, 13) + nk] = nametable1[POS!(17, 13) + nk] ^ 0xC;
                        nk++;
                    }
                }
            }
        } else {
            conveyor_cnt_middle--;
        }

        // Cycle conveyor_cnt[1] and conveyor_cnt[2] (drives pan spawn timing)
        let mut ci: u8 = 1;
        loop {
            if ci >= 3 { break; }
            if conveyor_dir[ci] != 0 {
                conveyor_cnt[ci]++;
                if conveyor_cnt[ci] > val { conveyor_cnt[ci] = 0; }
            } else {
                conveyor_cnt[ci]--;
                if conveyor_cnt[ci] >= val { conveyor_cnt[ci] = val - 1; }
            }
            ci++;
        }
    } else {
        if conveyor_cnt[1] == 0 {
            if conveyor_items[1] < 4 {
                if conveyor_dir[1] == 0 {
                    let mut dx1: i8 = 0;
                    if (rand() & 128) != 0 { dx1 = 1; }
                    if enemy_add(ENEMY_CEMENT_PAN, 0, 88, dx1) != 0 {
                        conveyor_items[1]++;
                    }
                }
            }
        }
        if conveyor_cnt[2] == 0 {
            if conveyor_items[2] < 4 {
                let dx2: i8 = conveyor_dir[2] as i8;
                if enemy_add(ENEMY_CEMENT_PAN, 0, 160, dx2) != 0 {
                    conveyor_items[2]++;
                }
            }
        }
    }

    // Barrel fire collision check
    if barrel_fire_x + 12 >= player_x + 4 {
        if barrel_fire_x + 4 < player_x + 12 {
            if barrel_fire_y + 6 >= player_y + 4 {
                if barrel_fire_y + 2 < player_y + 12 {
                    clear = LEVEL_LOSE;
                }
            }
        }
    }

    // Check Kong collision
    if player_y < (kong_y + 28) as u8 {
        if player_x + 12 > kong_x {
            if player_x < kong_x + 28 {
                clear = LEVEL_LOSE;
            }
        }
    }

    // Level ends when player reaches top platform
    if player_y == 40 {
        clear = LEVEL_CLEAR;
    }

    // Increase difficulty every 5 seconds, spawn fireballs
    if game_level_difficulty_count < 300 {
        game_level_difficulty_count++;
    } else {
        game_level_difficulty_count = 0;

        if game_fireballs < game_fireballs_max {
            game_fireballs++;
            enemy_add(ENEMY_FIREBALL_1_SPAWN, barrel_fire_x, barrel_fire_y + 8, 0);
            sfx_play(SFX_CHN+2, SFX_FIRE_SPAWN, barrel_fire_x+8);
        }
    }

    return clear;
}


// ============================================================================
// FUNCTION: Level 3 Kong Logic - Elevators and Bounces
// ============================================================================

far fn kong_process_level3() -> u8 {
    let mut clear: u8 = 0;

    kong_stand_animation_level2();
    game_show_kong(OAM_KONG, kong_x, kong_y);

    // Spawn bouncing springs
    if game_bounce_delay == 0 {
        let mut val: i16 = 180 - ((game_loops as i16) << 4);
        if val < 64 {
            val = 64;
        }

        game_bounce_delay = val as u16;

        let random_off: u8 = mod8(rand() as u8, (game_loops + 1) as u8) & 7;
        let bounce_x: i16 = if game_flip == 0 {
            -16 + (random_off as i16)
        } else {
            256 - (random_off as i16)
        };

        enemy_add(ENEMY_BOUNCE, bounce_x, (kong_y + 18) as u8, 0);
    } else {
        game_bounce_delay--;
    }

    // Increase difficulty every 10 seconds
    if game_level_difficulty_count < 600 {
        game_level_difficulty_count++;
    } else {
        game_level_difficulty_count = 0;

        if game_bounce_speed < 4 {
            game_bounce_speed++;
        }
    }

    // Level ends when player reaches top platform
    if player_y == 16 {
        clear = LEVEL_CLEAR;
    }

    return clear;
}


// ============================================================================
// FUNCTION: Level 4 Kong Logic - Rivets
// ============================================================================

far fn kong_process_level4() -> u8 {
    let mut clear: u8 = 0;

    kong_stand_animation_level2();
    game_show_kong(OAM_KONG, kong_x, kong_y);

    // Calculate difficulty interval (10s - game_loops/2, min 5s)
    // val = base * 60 = base * 64 - base * 4 = (base << 6) - (base << 2)
    let base: i16 = 10 - ((game_loops as i16) / 2);
    let mut val: i16 = (base << 6) - (base << 2);
    if val < 300 {
        val = 300;
    }

    // Increase difficulty and spawn fireballs
    if game_level_difficulty_count < val as u16 {
        game_level_difficulty_count++;
    } else {
        game_level_difficulty_count = 0;

        if game_fireballs < game_fireballs_max {
            game_fireballs++;

            // Find suitable spawn point
            let spawn_idx: u8 = mod8(rand() as u8, fireball_spawn_all);
            let fx: u8 = fireball_spawn_x[spawn_idx];
            let fy: u8 = fireball_spawn_y[spawn_idx];

            enemy_add(ENEMY_FIREBALL_2, fx, fy, 0);
            sfx_play(SFX_CHN+2, SFX_FIRE_SPAWN, fx+8);
        }
    }

    // Check Kong collision
    if player_y < (kong_y + 28) as u8 {
        if player_x + 12 > kong_x {
            if player_x < kong_x + 28 {
                clear = LEVEL_LOSE;
            }
        }
    }

    // Level ends when all rivets removed
    if game_rivets == 8 {
        clear = LEVEL_CLEAR;
    }

    return clear;
}


// ============================================================================
// FUNCTION: Process Kong Based on Current Level
// ============================================================================

far fn kong_process() -> u8 {
    if game_level == 0 {
        return kong_process_level1();
    } else if game_level == 1 {
        return kong_process_level2();
    } else if game_level == 2 {
        return kong_process_level3();
    } else {
        return kong_process_level4();
    }
}
