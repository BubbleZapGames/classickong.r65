// ============================================================================
// SNES Hardware Library for R65
// ============================================================================
// Comprehensive library for accessing all SNES hardware registers,
// with macros and helper functions for common operations.
// ============================================================================

// ============================================================================
// PPU REGISTERS ($2100-$213F)
// ============================================================================

// Screen Display Register
// Bit 7: Force blank (1=screen off)
// Bits 0-3: Master brightness (0=black, 15=full)
#[hw(0x2100)]
static mut INIDISP: u8;

// Object Size and Character Address
// Bits 5-7: Object size selection
// Bits 3-4: Name select (gap between obj char blocks)
// Bits 0-2: Name base address (in 16KB steps)
#[hw(0x2101)]
static mut OBSEL: u8;


// OAM Address (16-bit)
#[hw(0x2102)]
static mut OAMADD: u16;

// OAM Address (low byte)
#[hw(0x2102)]
static mut OAMADDL: u8;

// OAM Address (high byte) and Priority Rotation
// Bit 7: OAM priority rotation
// Bit 0: OAM address bit 9 (table select)
#[hw(0x2103)]
static mut OAMADDH: u8;

// OAM Data Write (write twice for each entry)
#[hw(0x2104)]
static mut OAMDATA: u8;

// BG Mode and Character Size
// Bit 7: BG4 tile size (0=8x8, 1=16x16)
// Bit 6: BG3 tile size
// Bit 5: BG2 tile size
// Bit 4: BG1 tile size
// Bit 3: BG3 priority in Mode 1
// Bits 0-2: BG mode (0-7)
#[hw(0x2105)]
static mut BGMODE: u8;

// Screen Pixelation (Mosaic)
// Bits 4-7: Mosaic size (0=1x1, 15=16x16)
// Bits 0-3: Enable mosaic for BG1-4
#[hw(0x2106)]
static mut MOSAIC: u8;

// BG1 Tilemap Address and Size
// Bits 2-7: Tilemap base address (in 2KB steps)
// Bit 1: Tilemap horizontal mirror (0=32, 1=64 tiles)
// Bit 0: Tilemap vertical mirror (0=32, 1=64 tiles)
#[hw(0x2107)]
static mut BG1SC: u8;

#[hw(0x2108)]
static mut BG2SC: u8;

#[hw(0x2109)]
static mut BG3SC: u8;

#[hw(0x210A)]
static mut BG4SC: u8;

// BG1/BG2 Character Data Address
// Bits 4-7: BG2 base address (in 8KB steps)
// Bits 0-3: BG1 base address (in 8KB steps)
#[hw(0x210B)]
static mut BG12NBA: u8;

// BG3/BG4 Character Data Address
#[hw(0x210C)]
static mut BG34NBA: u8;

// BG1 Horizontal Scroll (write twice: low then high)
#[hw(0x210D)]
static mut BG1HOFS: u8;

// BG1 Vertical Scroll (write twice: low then high)
#[hw(0x210E)]
static mut BG1VOFS: u8;

// BG2 Scroll Registers
#[hw(0x210F)]
static mut BG2HOFS: u8;

#[hw(0x2110)]
static mut BG2VOFS: u8;

// BG3 Scroll Registers
#[hw(0x2111)]
static mut BG3HOFS: u8;

#[hw(0x2112)]
static mut BG3VOFS: u8;

// BG4 Scroll Registers
#[hw(0x2113)]
static mut BG4HOFS: u8;

#[hw(0x2114)]
static mut BG4VOFS: u8;

// VRAM Address Increment Mode
// Bit 7: Increment after high/low byte (0=low, 1=high)
// Bits 2-3: Address translation (0=none, 1-3=various)
// Bits 0-1: Increment amount (0=1, 1=32, 2=128, 3=128)
#[hw(0x2115)]
static mut VMAIN: u8;

// VRAM Address (16-bit)
#[hw(0x2116)]
static mut VMADD: u16;

// VRAM Address (low byte)
#[hw(0x2116)]
static mut VMADDL: u8;

// VRAM Address (high byte)
#[hw(0x2117)]
static mut VMADDH: u8;

// VRAM Data Write (16-bit)
#[hw(0x2118)]
static mut VMDATA: u16;

// VRAM Data Write (low byte)
#[hw(0x2118)]
static mut VMDATAL: u8;

// VRAM Data Write (high byte)
#[hw(0x2119)]
static mut VMDATAH: u8;

// Mode 7 Settings
// Bit 7: Playfield size (0=wrap, 1=clip/fill)
// Bit 6: Fill with tile 0 or transparent
// Bit 1: Vertical flip
// Bit 0: Horizontal flip
#[hw(0x211A)]
static mut M7SEL: u8;

// Mode 7 Matrix Parameters (write twice each)
#[hw(0x211B)]
static mut M7A: u8;

#[hw(0x211C)]
static mut M7B: u8;

#[hw(0x211D)]
static mut M7C: u8;

#[hw(0x211E)]
static mut M7D: u8;

// Mode 7 Center Coordinates
#[hw(0x211F)]
static mut M7X: u8;

#[hw(0x2120)]
static mut M7Y: u8;

// CGRAM Address (palette)
#[hw(0x2121)]
static mut CGADD: u8;

// CGRAM Data Write (write twice: low then high)
#[hw(0x2122)]
static mut CGDATA: u8;

// Window 1 Left Position
#[hw(0x2126)]
static mut WH0: u8;

// Window 1 Right Position
#[hw(0x2127)]
static mut WH1: u8;

// Window 2 Left Position
#[hw(0x2128)]
static mut WH2: u8;

// Window 2 Right Position
#[hw(0x2129)]
static mut WH3: u8;

// Window Mask Settings for BG1/BG2
#[hw(0x2123)]
static mut W12SEL: u8;

// Window Mask Settings for BG3/BG4
#[hw(0x2124)]
static mut W34SEL: u8;

// Window Mask Settings for OBJ and Color Window
#[hw(0x2125)]
static mut WOBJSEL: u8;

// Window Mask Logic for BG
#[hw(0x212A)]
static mut WBGLOG: u8;

// Window Mask Logic for OBJ and Color
#[hw(0x212B)]
static mut WOBJLOG: u8;

// Main Screen Designation
// Bit 4: OBJ on main screen
// Bits 0-3: BG1-4 on main screen
#[hw(0x212C)]
static mut TM: u8;

// Sub Screen Designation
#[hw(0x212D)]
static mut TS: u8;

// Window Mask Main Screen
#[hw(0x212E)]
static mut TMW: u8;

// Window Mask Sub Screen
#[hw(0x212F)]
static mut TSW: u8;

// Color Addition Select
// Bit 7: Add/subtract mode (0=add, 1=subtract)
// Bit 6: Half color math
// Bits 0-5: Enable color math for BG1-4, OBJ, backdrop
#[hw(0x2130)]
static mut CGWSEL: u8;

// Color Math Designation
#[hw(0x2131)]
static mut CGADSUB: u8;

// Fixed Color Data
// Bits 5-7: Color plane select (BGR)
// Bits 0-4: Color intensity
#[hw(0x2132)]
static mut COLDATA: u8;

// Screen Mode/Video Select
// Bit 7: External sync
// Bit 6: Extbg mode
// Bit 5: Pseudo-hires
// Bit 4: Overscan (0=224, 1=239 lines)
// Bit 3: OBJ interlace
// Bit 2: Screen interlace
// Bits 0-1: Field size
#[hw(0x2133)]
static mut SETINI: u8;

// PPU Status Registers (read-only)
#[hw(0x2134)]
static mut MPYL: u8;    // Mode 7 multiply result (low)

#[hw(0x2135)]
static mut MPYM: u8;    // Mode 7 multiply result (mid)

#[hw(0x2136)]
static mut MPYH: u8;    // Mode 7 multiply result (high)

#[hw(0x2137)]
static mut SLHV: u8;    // Latch H/V counters

#[hw(0x2138)]
static mut OAMDATAREAD: u8;  // OAM Data Read

#[hw(0x2139)]
static mut VMDATALREAD: u8;  // VRAM Data Read (low)

#[hw(0x213A)]
static mut VMDATAHREAD: u8;  // VRAM Data Read (high)

#[hw(0x213B)]
static mut CGDATAREAD: u8;   // CGRAM Data Read

#[hw(0x213C)]
static mut OPHCT: u8;   // Horizontal Counter Latch

#[hw(0x213D)]
static mut OPVCT: u8;   // Vertical Counter Latch

#[hw(0x213E)]
static mut STAT77: u8;  // PPU1 Status

#[hw(0x213F)]
static mut STAT78: u8;  // PPU2 Status


// ============================================================================
// APU REGISTERS ($2140-$2143)
// ============================================================================

// APU I/O Ports (directly connected to SPC700)
#[hw(0x2140)]
static mut APUIO0: u8;

#[hw(0x2141)]
static mut APUIO1: u8;

#[hw(0x2142)]
static mut APUIO2: u8;

#[hw(0x2143)]
static mut APUIO3: u8;


// ============================================================================
// WRAM ACCESS REGISTERS ($2180-$2183)
// ============================================================================

// WRAM Data Read/Write
#[hw(0x2180)]
static mut WMDATA: u8;

// WRAM Address (low byte)
#[hw(0x2181)]
static mut WMADDL: u8;

// WRAM Address (middle byte)
#[hw(0x2182)]
static mut WMADDM: u8;

// WRAM Address (high byte - bit 0 only)
#[hw(0x2183)]
static mut WMADDH: u8;


// ============================================================================
// CPU REGISTERS ($4200-$421F)
// ============================================================================

// Interrupt Enable
// Bit 7: NMI enable
// Bit 5: V-blank IRQ enable
// Bit 4: H-blank IRQ enable
// Bit 0: Auto joypad read enable
#[hw(0x4200)]
static mut NMITIMEN: u8;

// Programmable I/O Port (directly accessible)
#[hw(0x4201)]
static mut WRIO: u8;

// Multiplicand A
#[hw(0x4202)]
static mut WRMPYA: u8;

// Multiplicand B
#[hw(0x4203)]
static mut WRMPYB: u8;

// Dividend (low byte)
#[hw(0x4204)]
static mut WRDIVL: u8;

// Dividend (high byte)
#[hw(0x4205)]
static mut WRDIVH: u8;

// Divisor
#[hw(0x4206)]
static mut WRDIVB: u8;

// H-Count Timer (16-bit)
#[hw(0x4207)]
static mut HTIME: u16;

// H-Count Timer (low byte)
#[hw(0x4207)]
static mut HTIMEL: u8;

// H-Count Timer (high byte)
#[hw(0x4208)]
static mut HTIMEH: u8;

// V-Count Timer (16-bit)
#[hw(0x4209)]
static mut VTIME: u16;

// V-Count Timer (low byte)
#[hw(0x4209)]
static mut VTIMEL: u8;

// V-Count Timer (high byte)
#[hw(0x420A)]
static mut VTIMEH: u8;

// DMA Enable
#[hw(0x420B)]
static mut MDMAEN: u8;

// HDMA Enable
#[hw(0x420C)]
static mut HDMAEN: u8;

// ROM Speed (0=slow, 1=fast)
#[hw(0x420D)]
static mut MEMSEL: u8;

// NMI Flag and CPU Version (read-only)
// Bit 7: NMI flag (cleared on read)
// Bits 0-3: CPU version
#[hw(0x4210)]
static mut RDNMI: u8;

// IRQ Flag and Status (read-only)
// Bit 7: IRQ flag
// Bit 6: Auto joypad read in progress
#[hw(0x4211)]
static mut TIMEUP: u8;

// PPU Status (read-only)
// Bit 7: V-blank flag
// Bit 6: H-blank flag
// Bit 0: Auto joypad read status
#[hw(0x4212)]
static mut HVBJOY: u8;

// Programmable I/O Port (read-only)
#[hw(0x4213)]
static mut RDIO: u8;

// Division Result
#[hw(0x4214)]
static mut RDDIV: u16;

// Division Result (quotient, low byte)
#[hw(0x4214)]
static mut RDDIVL: u8;

// Division Result (quotient, high byte)
#[hw(0x4215)]
static mut RDDIVH: u8;

// Multiplication Result / Division Remainder
#[hw(0x4216)]
static mut RDMPY: u16;

// Multiplication Result / Division Remainder (low byte)
#[hw(0x4216)]
static mut RDMPYL: u8;

// Multiplication Result / Division Remainder (high byte)
#[hw(0x4217)]
static mut RDMPYH: u8;


// ============================================================================
// JOYPAD REGISTERS ($4218-$421F)
// ============================================================================

// Controller 1 Data (directly accessed, active low bits)
#[hw(0x4218)]
static mut JOY1L: u8;

#[hw(0x4219)]
static mut JOY1H: u8;

// Controller 2 Data
#[hw(0x421A)]
static mut JOY2L: u8;

#[hw(0x421B)]
static mut JOY2H: u8;

// Controller 3 Data (directly accessed via controller port extension)
#[hw(0x421C)]
static mut JOY3L: u8;

#[hw(0x421D)]
static mut JOY3H: u8;

// Controller 4 Data
#[hw(0x421E)]
static mut JOY4L: u8;

#[hw(0x421F)]
static mut JOY4H: u8;


// ============================================================================
// DMA REGISTERS ($4300-$437F) - Channel 0
// ============================================================================

// DMA Control (Channel 0)
// Bit 7: Transfer direction (0=A->B, 1=B->A)
// Bit 6: HDMA indirect addressing
// Bit 5: Unused
// Bit 4: HDMA address mode (0=increment, 1=fixed)
// Bit 3: A-Bus increment (0=increment, 1=decrement)
// Bits 0-2: Transfer mode
#[hw(0x4300)]
static mut DMAP0: u8;

// DMA Destination Register (Channel 0)
// B-Bus address (added to $2100)
#[hw(0x4301)]
static mut BBAD0: u8;

// DMA Source Address (Channel 0, 16-bit)
#[hw(0x4302)]
static mut A1T0: u16;

#[hw(0x4302)]
static mut A1T0L: u8;

#[hw(0x4303)]
static mut A1T0H: u8;

#[hw(0x4304)]
static mut A1B0: u8;

// DMA Size / HDMA Indirect Address (Channel 0, 16-bit)
#[hw(0x4305)]
static mut DAS0: u16;

#[hw(0x4305)]
static mut DAS0L: u8;

#[hw(0x4306)]
static mut DAS0H: u8;

// HDMA Indirect Bank (Channel 0)
#[hw(0x4307)]
static mut DASB0: u8;

// HDMA Table Address (Channel 0, 16-bit)
#[hw(0x4308)]
static mut A2A0: u16;

#[hw(0x4308)]
static mut A2A0L: u8;

#[hw(0x4309)]
static mut A2A0H: u8;

// HDMA Line Counter (Channel 0)
#[hw(0x430A)]
static mut NTRL0: u8;


