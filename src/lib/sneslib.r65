// ============================================================================
// CONSTANTS - Screen Dimensions
// ============================================================================

const SCREEN_WIDTH: u16 = 256;
const SCREEN_HEIGHT_NORMAL: u16 = 224;
const SCREEN_HEIGHT_OVERSCAN: u16 = 239;

const TILES_PER_ROW: u8 = 32;
const TILES_PER_COL_NORMAL: u8 = 28;
const TILES_PER_COL_OVERSCAN: u8 = 30;


// ============================================================================
// CONSTANTS - Tile/Sprite Sizes
// ============================================================================

const TILE_SIZE_8: u8 = 8;
const TILE_SIZE_16: u8 = 16;

enum TileSize { Bpp2 = 16, Bpp4 = 32, Bpp8 = 64 }


// ============================================================================
// CONSTANTS - INIDISP Values
// ============================================================================

enum Brightness { Off = 0x00, Full = 0x0F }
const FORCE_BLANK: u8 = 0x80;


// ============================================================================
// ENUMS - BgMode Values
// ============================================================================

enum BG {
    Mode0 = 0x00,  // 4 layers, 4 colors each
    Mode1 = 0x01,  // 2 layers 16 colors, 1 layer 4 colors
    Mode2 = 0x02,  // 2 layers 16 colors, offset-per-tile
    Mode3 = 0x03,  // 1 layer 256 colors, 1 layer 16 colors
    Mode4 = 0x04,  // 1 layer 256 colors, 1 layer 4 colors, OPT
    Mode5 = 0x05,  // 1 layer 16 colors, 1 layer 4 colors, hires
    Mode6 = 0x06,  // 1 layer 16 colors, OPT, hires
    Mode7 = 0x07   // 1 layer 256 colors, rotation/scaling
}

enum BgTileSize {
     BG1_16x16 = 0x10,
     BG2_16x16 = 0x20,
     BG3_16x16 = 0x40, 
     BG4_16x16 = 0x80 
}


// ============================================================================
// ENUMS - ObjSize Object Sizes
// ============================================================================

enum ObjSize {
    T8x8_16x16   = 0x00,
    T8x8_32x32   = 0x20,
    T8x8_64x64   = 0x40,
    T16x16_32x32 = 0x60,
    T16x16_64x64 = 0x80,
    T32x32_64x64 = 0xA0,
    T16x32_32x64 = 0xC0,
    T16x32_32x32 = 0xE0
}


// ============================================================================
// CONSTANTS - VMAIN Increment Modes
// ============================================================================

enum VmainTrigger { Low = 0x00, High = 0x80 }    // Increment after low/high byte write
enum VmainStep { By1 = 0x00, By32 = 0x01, By128 = 0x02 }  // Increment step size


// ============================================================================
// ENUMS - DMA Transfer Modes
// ============================================================================

enum DmaTransferMode {
    OneReg   = 0x00,  // 1 register, write once
    TwoReg   = 0x01,  // 2 registers, write once each (L,H)
    OneRegX2 = 0x02,  // 1 register, write twice
    TwoRegX2 = 0x03,  // 2 registers, write twice each (L,L,H,H)
    FourReg  = 0x04   // 4 registers, write once each
}

enum DmaDirection { ToPPU = 0x00, ToCPU = 0x80 }
enum DmaAddress { Increment = 0x00, Decrement = 0x10, Fixed = 0x08 }


// ============================================================================
// CONSTANTS - NMITIMEN Interrupt Flags
// ============================================================================

enum Interrupt { Nmi = 0x80, IrqV = 0x20, IrqHV = 0x30, AutoJoy = 0x01 }


// ============================================================================
// CONSTANTS - TM/TS Main/Sub Screen Enables
// ============================================================================

enum Screen { BG1 = 0x01, BG2 = 0x02, BG3 = 0x04, BG4 = 0x08, Obj = 0x10 }


// ============================================================================
// CONSTANTS - Joypad Button Masks
// ============================================================================

enum Joy {
    B      = 0x8000,
    Y      = 0x4000,
    Select = 0x2000,
    Start  = 0x1000,
    Up     = 0x0800,
    Down   = 0x0400,
    Left   = 0x0200,
    Right  = 0x0100,
    A      = 0x0080,
    X      = 0x0040,
    L      = 0x0020,
    R      = 0x0010
}


// ============================================================================
// CONSTANTS - Color Math
// ============================================================================

enum ColorMath {
    Add      = 0x00,
    Sub      = 0x80,
    Half     = 0x40,
    BG1      = 0x01,
    BG2      = 0x02,
    BG3      = 0x04,
    BG4      = 0x08,
    Obj      = 0x10,
    Backdrop = 0x20
}

enum ColorChannel { Red = 0x20, Green = 0x40, Blue = 0x80 }


// ============================================================================
// CONSTANTS - VRAM Addresses (word addresses)
// ============================================================================

const VRAM_BG1_TILES: u16 = 0x0000;
const VRAM_BG2_TILES: u16 = 0x4000;
const VRAM_BG1_MAP: u16 = 0x7000;
const VRAM_BG2_MAP: u16 = 0x7400;
const VRAM_OBJ_TILES: u16 = 0x6000;

// OAM sprite entry (4 bytes, packed)
// attr byte: V H PP PPP N
//   Bit 7: vertical flip, Bit 6: horizontal flip
//   Bits 5-4: priority (0-3), Bits 3-1: palette (0-7), Bit 0: name table
struct OamEntry {
    x: u8,
    y: u8,
    tile: u8,
    attr: u8
}

// OAM attribute enums
enum OamFlip { V = 0x80, H = 0x40, VH = 0xC0 }

enum OamPriority {
    Behind  = 0x00,
    Low     = 0x10,
    High    = 0x20,
    InFront = 0x30
}

enum OamPalette {
    Palette0 = 0x00,
    Palette1 = 0x02,
    Palette2 = 0x04,
    Palette3 = 0x06,
    Palette4 = 0x08,
    Palette5 = 0x0A,
    Palette6 = 0x0C,
    Palette7 = 0x0E
}

// OAM entry helper macros
impl OamEntry {
    // Set position, tile, and clear attributes
    // Usage: sprite.set!(x, y, tile);
    macro_rules! set($x:expr, $y:expr, $tile:expr) {
        self.x = $x;
        self.y = $y;
        self.tile = $tile;
        self.attr = 0;
    }

    // Set position, tile, and attributes in one call
    // Usage: sprite.set_all!(x, y, tile, OamPriority::High as u8 | OamPalette::Palette1 as u8);
    macro_rules! set_all($x:expr, $y:expr, $tile:expr, $attr:expr) {
        self.x = $x;
        self.y = $y;
        self.tile = $tile;
        self.attr = $attr;
    }

    // Set priority (clears old priority bits, preserves others)
    // Usage: sprite.set_priority!(OamPriority::High);
    macro_rules! set_priority($pri:expr) {
        self.attr = (self.attr & 0xCF) | ($pri as u8);
    }

    // Set palette (clears old palette bits, preserves others)
    // Usage: sprite.set_palette!(OamPalette::Palette3);
    macro_rules! set_palette($pal:expr) {
        self.attr = (self.attr & 0xF1) | ($pal as u8);
    }

    // Set horizontal flip
    // Usage: sprite.flip_h!();
    macro_rules! flip_h() {
        self.attr = self.attr | OamFlip::H as u8;
    }

    // Set vertical flip
    // Usage: sprite.flip_v!();
    macro_rules! flip_v() {
        self.attr = self.attr | OamFlip::V as u8;
    }

    // Set vertical flip
    // Usage: sprite.flip_hv!();
    macro_rules! flip_hv() {
        self.attr = self.attr | OamFlip::H as u8 | OamFlip::V as u8;
    }

    // Clear all flip flags
    // Usage: sprite.clear_flip!();
    macro_rules! clear_flip() {
        self.attr = self.attr & 0x3F;
    }

    // Use second name table (tile numbers 256-511)
    // Usage: sprite.name_table_1!();
    macro_rules! name_table_1() {
        self.attr = self.attr | 0x01;
    }

    // Hide sprite (move Y off-screen)
    // Usage: sprite.hide!();
    macro_rules! hide() {
        self.y = 240;
    }

    // Write this entry to OAM hardware at sprite index N (0-127).
    // Sets OAMADD to N*2 then writes 4 bytes via OAMDATA.
    // Usage: sprite.write_oam!(0);   // Write to sprite slot 0
    macro_rules! write_oam($index:expr) {
        OAMADD = ($index as u16) * 2;
        OAMDATA = self.x;
        OAMDATA = self.y;
        OAMDATA = self.tile;
        OAMDATA = self.attr;
    }
}

// SPC700 transfer states
const SPC_READY: u8 = 0xAA;
const SPC_BEGIN: u8 = 0xCC;


// ============================================================================
// CONSTANTS - RGB Color Masks (for 15-bit BGR colors)
// ============================================================================

const R_MASK: u16 = 0x001F;  // Red component (bits 0-4)
const G_MASK: u16 = 0x03E0;  // Green component (bits 5-9)
const B_MASK: u16 = 0x7C00;  // Blue component (bits 10-14)

// ============================================================================
// CONSTANTS - Background Tile Attribute Flags (for tilemap entries)
// ============================================================================

enum BgAttr { HFlip = 0x4000, VFlip = 0x8000, Priority = 0x2000 }

enum BgPalette {
    Palette0 = 0x0000, // Palette 0
    Palette1 = 0x0400, // Palette 1
    Palette2 = 0x0800, // Palette 2
    Palette3 = 0x0C00, // Palette 3
    Palette4 = 0x1000, // Palette 4
    Palette5 = 0x1400, // Palette 5
    Palette6 = 0x1800, // Palette 6
    Palette7 = 0x1C00  // Palette 7
}

// ============================================================================
// MACROS - Screen Control
// ============================================================================

// Set screen brightness (0-15), disables force blank
// Usage: set_brightness!(15);
macro_rules! set_brightness($brightness:expr) {
    INIDISP = $brightness & 0x0F;
}

// Turn screen off (force blank)
// Usage: set_screen_off!();
macro_rules! set_screen_off() {
    INIDISP = FORCE_BLANK;
}

// ============================================================================
// MACROS - VRAM Access
// ============================================================================

// Set VRAM address for writing
// Usage: set_vram_addr!(0x0000);
macro_rules! set_vram_addr($addr:expr) {
    VMADD = $addr as u16;
}

// Set VRAM increment mode
// Usage: set_vram_inc!(VmainTrigger::High);
macro_rules! set_vram_inc($mode:expr) {
    VMAIN = $mode as u8;
}

// Write word to VRAM
// Usage: write_vram!(0x1234);
macro_rules! write_vram($data:expr) {
    VMDATA = $data as u16;
}

// ============================================================================
// MACROS - CGRAM (Palette) Access
// ============================================================================

// Set CGRAM address (color index 0-255)
// Usage: set_cgram_addr!(0);
macro_rules! set_cgram_addr($index:expr) {
    CGADD = $index as u8;
}

// Write 15-bit color to CGRAM
// Usage: write_color!(0x7FFF);  // White
macro_rules! write_color($color:expr) {
    A = $color as u16;
    CGDATA = A as u8
    CGDATA = B
}

// Write RGB color to CGRAM (each component 0-31)
// Usage: write_rgb!(31, 0, 0);  // Red
macro_rules! write_rgb($r:literal, $g:literal, $b:literal) {
    CGDATA = (($g & 0x07) << 5) | ($r & 0x1F);
    CGDATA = (($b & 0x1F) << 2) | (($g >> 3) & 0x03);
}

// Set backdrop (color 0) color
// Usage: set_backdrop!(0x001F);  // Red backdrop
macro_rules! set_backdrop($color:expr) {
    CGADD = 0;
    A = $color as u16;
    CGDATA = A as u8;
    CGDATA = B;
}


// ============================================================================
// MACROS - OAM Access
// ============================================================================

// Set OAM address
// Usage: set_oam_addr!(0);
macro_rules! set_oam_addr($addr:expr) {
    OAMADD = $addr as u16;
}

// Write sprite entry to OAM (4 bytes)
// Usage: write_oam_entry!(x, y, tile, attr);
macro_rules! write_oam_entry($x:expr, $y:expr, $tile:expr, $attr:expr) {
    OAMDATA = $x;
    OAMDATA = $y;
    OAMDATA = $tile;
    OAMDATA = $attr;
}


// ============================================================================
// MACROS - Background Setup
// ============================================================================

// Set BG mode (0-7) with optional tile size flags
// Usage: set_bgmode!(BG::Mode1, BgTileSize::BG1_16x16);
macro_rules! set_bgmode($mode:expr, $sizes:expr) {
    BGMODE = ($mode as u8 & 0x07) | $sizes;
}

// Set BG1 tilemap address and size
// addr: tilemap address in 2KB units (0-31)
// size: 0=32x32, 1=64x32, 2=32x64, 3=64x64
// Usage: set_bg1_map!(0x38, 0);  // $7000 word addr, 32x32
macro_rules! set_bg1_map($addr:expr, $size:expr) {
    BG1SC = ($addr << 2) | ($size & 0x03);
}

macro_rules! set_bg2_map($addr:expr, $size:expr) {
    BG2SC = ($addr << 2) | ($size & 0x03);
}

macro_rules! set_bg3_map($addr:expr, $size:expr) {
    BG3SC = ($addr << 2) | ($size & 0x03);
}

macro_rules! set_bg4_map($addr:expr, $size:expr) {
    BG4SC = ($addr << 2) | ($size & 0x03);
}

// Set BG1/BG2 character base addresses (in 8KB units, 0-15)
// Usage: set_bg12_chr!(0, 4);  // BG1 at $0000, BG2 at $8000
macro_rules! set_bg12_chr($bg1:expr, $bg2:expr) {
    BG12NBA = ($bg1 & 0x0F) | (($bg2 & 0x0F) << 4);
}

macro_rules! set_bg34_chr($bg3:expr, $bg4:expr) {
    BG34NBA = ($bg3 & 0x0F) | (($bg4 & 0x0F) << 4);
}

// Set BG scroll position (writes twice for 10-bit value)
// Usage: set_bg1_scroll!(hscroll, vscroll);
macro_rules! set_bg1_hscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG1HOFS = A as u8;
    BG1HOFS = B;
}

macro_rules! set_bg1_vscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG1VOFS = A as u8;
    BG1VOFS = B;
}

macro_rules! set_bg2_hscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG2HOFS = A as u8;
    BG2HOFS = B;
}

macro_rules! set_bg2_vscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG2VOFS = A as u8;
    BG2VOFS = B;
}

macro_rules! set_bg3_hscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG3HOFS = A as u8;
    BG3HOFS = B;
}

macro_rules! set_bg3_vscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG3VOFS = A as u8;
    BG3VOFS = B;
}

macro_rules! set_bg4_hscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG4HOFS = A as u8;
    BG4HOFS = B;
}

macro_rules! set_bg4_vscroll($scroll:expr) {
    A = ($scroll) as u16;
    BG4VOFS = A as u8;
    BG4VOFS = B;
}

// ============================================================================
// MACROS - Screen Layers
// ============================================================================

// Set layers on main screen
// Usage: set_main_layers!(Screen::BG1 | Screen::Obj);
macro_rules! set_main_layers($layers:expr) {
    TM = $layers;
}

// Set layers on sub screen
// Usage: set_sub_layers!(Screen::BG2);
macro_rules! set_sub_layers($layers:expr) {
    TS = $layers;
}

// ============================================================================
// MACROS - Object/Sprite Settings
// ============================================================================

// Set object size and name base
// Usage: set_obj_sel!(ObjSize::T8x8_16x16, 0, 0);
macro_rules! set_obj_sel($size:expr, $base:expr, $gap:expr) {
    OBSEL = $size as u8 | ($base & 0x07) | (($gap & 0x03) << 3);
}

// ============================================================================
// MACROS - Interrupt Control
// ============================================================================

// Enable NMI
// Usage: enable_nmi!();
macro_rules! enable_nmi() {
    NMITIMEN = NMITIMEN | Interrupt::Nmi;
}

// Disable NMI
// Usage: disable_nmi!();
macro_rules! disable_nmi() {
    NMITIMEN = NMITIMEN & 0x7F;
}

// Enable auto-joypad read
// Usage: enable_autojoy!();
macro_rules! enable_autojoy() {
    NMITIMEN |= Interrupt::AutoJoy;
}

// Set all interrupt flags at once
// Usage: set_nmitimen!(Interrupt::Nmi | Interrupt::AutoJoy);
macro_rules! set_nmitimen($flags:expr) {
    NMITIMEN = $flags;
}

// Clear pending NMI (read RDNMI)
// Usage: clear_nmi!();
macro_rules! clear_nmi() {
    A = RDNMI;
}

// ============================================================================
// MACROS - DMA Helper Macros
// ============================================================================
// Low-level helpers for custom DMA configurations.
// Uses WLA-DX operators: #< (low byte), #> (high byte), #^ (bank byte)
// ============================================================================

// Set DMA source address from a far pointer/label
// Usage: dma_set_src!(0, my_graphics_data);
macro_rules! dma_set_src($channel:literal, $ptr:ident) {
    const_assert!($channel < 8, "DMA channel must be 0-7");
    asm!(
        "LDA #<{PTR}",
        "STA A1T{CH}L",
        "LDA #>{PTR}",
        "STA A1T{CH}H",
        "LDA #:{PTR}",
        "STA A1B{CH}",
        PTR=symbol!($ptr), CH=$channel
    );
}

// Set DMA destination with 24-bit address (for WRAM transfers)
// Combines WRAM address setup (WMADDL/M/H) with DMA mode/BBAD configuration
// Usage: dma_set_dest!(0, DmaTransferMode::OneReg, 0x7E2000);
macro_rules! dma_set_dest($channel:literal, $mode:literal, $dest:ident) {
    const_assert!($channel < 8, "DMA channel must be 0-7");
    asm!(
        "LDA #<{DEST}",
        "STA WMADDL",
        "LDA #>{DEST}",
        "STA WMADDM",
        "LDA #^{DEST}",
        "STA WMADDH",
        "LDA #{MODE}",
        "STA DMAP{CH}",
        "LDA #$80",
        "STA BBAD{CH}",
        DEST=$dest, MODE=stringify!($mode), CH=$channel
    );
}

// Set DMA destination for PPU registers (B-bus address) and transfer mode
// Usage: dma_set_ppu_dest!(0, DmaTransferMode::TwoReg, 0x18);
macro_rules! dma_set_ppu_dest($channel:literal, $mode:expr, $bbad:literal) {
    const_assert!($channel < 8, "DMA channel must be 0-7");
    STATUS.A16 = false;  // Ensure 8-bit A (emits SEP #$20 only if needed)
    asm!(
        "LDA #{MODE}",
        "STA DMAP{CH}",
        "LDA #{BBAD}",
        "STA BBAD{CH}",
        MODE=stringify!($mode), BBAD=$bbad, CH=$channel
    );
}

// Set DMA transfer size
// Usage: dma_set_size!(0, 4096);
macro_rules! dma_set_size($channel:literal, $size:literal) {
    const_assert!($channel < 8, "DMA channel must be 0-7");
    asm!(
        "LDX #{SIZE}",
        "STX DAS{CH}",
        SIZE=$size, CH=$channel
    );
}

// Trigger DMA transfer on a channel
// Usage: dma_trigger!(0);  // Trigger channel 0
macro_rules! dma_trigger($channel:literal) {
    const_assert!($channel < 8, "DMA channel must be 0-7");
    MDMAEN = 1 << $channel;
}

// ============================================================================
// MACROS - DMA Operations (Const - Compile-time addresses)
// ============================================================================
// These macros use WLA-DX operators (#<, #>, #:) to extract address bytes
// at assemble time. All parameters must be compile-time constants or labels.
// For runtime/dynamic addresses, use the function versions below.
// ============================================================================

// DMA copy to VRAM (const version - compile-time source address)
// Usage: dma_copy_vram_const!(0, src_label, dest_vram, size);
// Note: src should be a WLA-DX label (e.g., sprites1_gfx_data), not an R65 variable
macro_rules! dma_copy_vram_const($channel:literal, $src:ident, $dest:ident, $size:literal) {
    STATUS.A16 = false;  // Ensure 8-bit A (emits SEP #$20 only if needed)
    asm!(
        "LDA #$80",       // VmainTrigger::High
        "STA VMAIN",      // Store to VMAIN
        "LDX #{DEST}",
        "STX VMADD",
        DEST=$dest
    );
    dma_set_src!($channel, $src);
    dma_set_size!($channel, $size);
    dma_set_ppu_dest!($channel, 1, 24);  // 1 = DMA_MODE_2REG_1WRITE, 24 = $18 (VMDATAL)
    dma_trigger!($channel);
}

// DMA copy to CGRAM (palette) - const version
// Usage: dma_copy_cgram_const!(0, src_label, start_color, num_colors);
macro_rules! dma_copy_cgram_const($channel:literal, $src:ident, $start:expr, $count:literal) {
    STATUS.A16 = false;  // Ensure 8-bit A (emits SEP #$20 only if needed)
    asm!(
        "LDA #{START}",
        "STA CGADD",
        START=$start
    );
    dma_set_src!($channel, $src);
    asm!(
        "LDX #({COUNT} * 2)",
        "STX DAS{CH}",
        COUNT=$count, CH=$channel
    );
    dma_set_ppu_dest!($channel, 2, 34);  // 2 = DMA_MODE_1REG_2WRITE, 34 = $22 (CGDATA)
    dma_trigger!($channel);
}

// DMA copy to OAM (sprites) - const version
// Usage: dma_copy_oam_const!(0, src_label, size);
macro_rules! dma_copy_oam_const($channel:literal, $src:ident, $size:literal) {
    OAMADDL = 0;
    OAMADDH = 0;
    dma_set_src!($channel, $src);
    dma_set_size!($channel, $size);
    dma_set_ppu_dest!($channel, 0, 4);  // 0 = DMA_MODE_1REG_1WRITE, 4 = $04 (OAMDATA)
    dma_trigger!($channel);
}

// ============================================================================
// FUNCTIONS - DMA Operations (Runtime - Dynamic addresses)
// ============================================================================
// These functions accept far pointers for runtime/dynamic source addresses.
// For compile-time known addresses, prefer the const macros for efficiency.
//
// Note: Functions use () syntax, macros use !() syntax:
//   dma_copy_vram_const!(...)  - macro for compile-time addresses
//   dma_copy_vram(...)         - function for runtime addresses
// ============================================================================

// Lookup table for DMA channel trigger bits
static dma_trigger_masks: [u8; 8] = [0x01, 0x02, 0x04, 0x08, 0x10, 0x20, 0x40, 0x80];

// DMA copy to VRAM (function version - far pointer)
// Usage: dma_copy_vram(channel, &my_data as far *u8, vram_offset, size);
// channel: DMA channel (0-7)
// src: 24-bit far pointer to source data
// vram_offset: destination VRAM word address
// size: number of bytes to transfer
far fn dma_copy_vram(channel: u8, src: far *u8, vram_offset: u16, size: u16) {
    // Save channel for trigger lookup
    Y = channel;

    // Compute DMA register base offset (channel * 16)
    X = channel << 4;

    // VRAM setup
    VMAIN = 0x80;
    VMADD = vram_offset;

    // DMA register writes - X-indexed STA requires assembly
    A = 0x01;
    asm!("STA $4300,X");  // DMAPn - 2 regs, increment
    A = 0x18;
    asm!("STA $4301,X");  // BBADn - VMDATAL
    A = src as u8;
    asm!("STA $4302,X");  // src lo
    A = ((src as u16) >> 8) as u8;
    asm!("STA $4303,X");  // src hi
    A = src.bank_byte();
    asm!("STA $4304,X");  // src bank
    A = size as u8;
    asm!("STA $4305,X");  // size lo
    A = (size >> 8) as u8;
    asm!("STA $4306,X");  // size hi

    // Trigger DMA
    MDMAEN = dma_trigger_masks[Y];
}

// DMA copy to CGRAM (function version - far pointer)
// Usage: dma_copy_cgram(channel, &palette_data as far *u8, start_color, num_bytes);
// channel: DMA channel (0-7)
// src: 24-bit far pointer to source data
// start_color: starting color index (0-255)
// num_bytes: number of bytes to transfer (colors * 2)
far fn dma_copy_cgram(channel: u8, src: far *u8, start_color: u16, num_bytes: u16) {
    // Save channel for trigger lookup
    Y = channel;

    // Compute DMA register base offset (channel * 16)
    X = channel << 4;

    // CGRAM setup
    CGADD = start_color as u8;

    // DMA register writes - X-indexed STA requires assembly
    A = 0x02;
    asm!("STA $4300,X");  // DMAPn - 1 reg, write twice
    A = 0x22;
    asm!("STA $4301,X");  // BBADn - CGDATA
    A = src as u8;
    asm!("STA $4302,X");  // src lo
    A = ((src as u16) >> 8) as u8;
    asm!("STA $4303,X");  // src hi
    A = src.bank_byte();
    asm!("STA $4304,X");  // src bank
    A = num_bytes as u8;
    asm!("STA $4305,X");  // num_bytes lo
    A = (num_bytes >> 8) as u8;
    asm!("STA $4306,X");  // num_bytes hi

    // Trigger DMA
    MDMAEN = dma_trigger_masks[Y];
}

// DMA copy to OAM (function version - far pointer)
// Usage: dma_copy_oam(channel, &oam_data as far *u8, size);
// channel: DMA channel (0-7)
// src: 24-bit far pointer to source data
// size: number of bytes to transfer (usually 544)
far fn dma_copy_oam(channel: u8, src: far *u8, size: u16) {
    // Save channel for trigger lookup
    Y = channel;

    // Compute DMA register base offset (channel * 16)
    X = channel << 4;

    // OAM setup
    OAMADD = 0;

    // DMA register writes - X-indexed STA requires assembly
    A = 0x00;
    asm!("STA $4300,X");  // DMAPn - 1 reg, write once
    A = 0x04;
    asm!("STA $4301,X");  // BBADn - OAMDATA
    A = src as u8;
    asm!("STA $4302,X");  // src lo
    A = ((src as u16) >> 8) as u8;
    asm!("STA $4303,X");  // src hi
    A = src.bank_byte();
    asm!("STA $4304,X");  // src bank
    A = size as u8;
    asm!("STA $4305,X");  // size lo
    A = (size >> 8) as u8;
    asm!("STA $4306,X");  // size hi

    // Trigger DMA
    MDMAEN = dma_trigger_masks[Y];
}


// DMA fill VRAM with a value (fixed source address mode)
// Usage: dma_fill_vram!(0, dest_vram, src, size);
macro_rules! dma_fill_vram($channel:literal, $dest:ident, $src:ident, $size:literal) {
    VMAIN = VmainTrigger::High;
    asm!(
        "LDX #{DEST}",
        "STX VMADD",
        DEST=$dest
    );
    dma_set_src!($channel, $src);
    dma_set_size!($channel, $size);
    dma_set_ppu_dest!($channel, 9, 24);  // 9 = DMA_MODE_2REG_1WRITE | DMA_FIXED, 24 = $18
    dma_trigger!($channel);
}

// DMA copy from VRAM to RAM
// Usage: dma_copy_from_vram!(0, src_vram, dest_ptr, size);
macro_rules! dma_copy_from_vram($channel:literal, $src:ident, $dest:ident, $size:literal) {
    VMAIN = VmainTrigger::High;
    asm!(
        "LDX #{SRC}",
        "STX VMADD",
        SRC=$src
    );
    dma_set_src!($channel, $dest);
    dma_set_size!($channel, $size);
    dma_set_ppu_dest!($channel, 129, 57);  // 129 = DMA_MODE_2REG_1WRITE | DMA_DIRECTION_TO_CPU, 57 = $39
    dma_trigger!($channel);
}

// DMA copy to WRAM (ROM to RAM or RAM to WRAM)
// Usage: dma_copy_wram!(0, dest_wram, src, size);
macro_rules! dma_copy_wram($channel:literal, $dest:ident, $src:ident, $size:literal) {
    dma_set_src!($channel, $src);
    dma_set_size!($channel, $size);
    dma_set_dest!($channel, 0, $dest);  // 0 = DMA_MODE_1REG_1WRITE
    dma_trigger!($channel);
}

// ============================================================================
// MACROS - HDMA Setup
// ============================================================================

// Enable HDMA channels
// Usage: enable_hdma!(0x01);  // Channel 0
macro_rules! dma_set_hdma($channels:expr) {
    HDMAEN = $channels;
}

// Disable all HDMA
// Usage: dma_disable_hdma!();
macro_rules! dma_disable_hdma() {
    HDMAEN = 0;
}

// ============================================================================
// MACROS - Mode 7
// ============================================================================

// Set Mode 7 matrix parameter A (cosine for rotation)
// Usage: set_m7a!(0x0100);  // 1.0 in fixed point
macro_rules! set_m7a($val:expr) {
    A = $val as u16;
    M7A = A as u8;
    M7A = B;
}

macro_rules! set_m7b($val:expr) {
    A = $val as u16;
    M7B = A as u8;
    M7B = B;
}

macro_rules! set_m7c($val:expr) {
    A = $val as u16;
    M7C = A as u8;
    M7C = B;
}

macro_rules! set_m7d($val:expr) {
    A = $val as u16;
    M7D = A as u8;
    M7D = B;
}

// Set Mode 7 center point
// Usage: set_m7_center!(128, 112);
macro_rules! set_m7_center($x:expr, $y:expr) {
    A = $x as u16;
    M7X = A as u8;
    M7X = B;
    A = $y as u16;
    M7Y = A as u8;
    M7Y = B;
}


// ============================================================================
// MACROS - Color Math
// ============================================================================

// Set fixed color for color math
// Usage: set_fixed_color!(ColorChannel::Red | 15);  // Red = 15
macro_rules! set_fixed_color($color:expr) {
    COLDATA = $color;
}

// Set fixed color RGB (each 0-31)
// Usage: set_fixed_rgb!(31, 31, 31);  // White
macro_rules! set_fixed_rgb($r:literal, $g:literal, $b:literal) {
    COLDATA = ColorChannel::Red | ($r & 0x1F) | ColorChannel::Green | ($g & 0x1F) | ColorChannel::Blue | ($b & 0x1F);
}


// ============================================================================
// MACROS - Window
// ============================================================================

// Set Window 1 bounds
// Usage: set_window1!(32, 224);
macro_rules! set_window1($left:expr, $right:expr) {
    WH0 = $left;
    WH1 = $right;
}

// Set Window 2 bounds
// Usage: set_window2!(64, 192);
macro_rules! set_window2($left:expr, $right:expr) {
    WH2 = $left;
    WH3 = $right;
}

// ============================================================================
// MACROS - IRQ Timers
// ============================================================================

// Set H-count IRQ position (0-339)
// Usage: set_hirq!(128);
macro_rules! set_hirq($pos:expr) {
    HTIME = $pos as u16;
}

// Set V-count IRQ position (0-261 NTSC, 0-311 PAL)
// Usage: set_virq!(200);
macro_rules! set_virq($pos:expr) {
    VTIME = $pos as u16;
}

// ============================================================================
// HELPER FUNCTIONS - Loops and Complex Operations
// ============================================================================

// Wait for VBlank
macro_rules! wait_nmi() {
    asm!("WAI");
}

// Wait for auto-joypad read to complete
macro_rules! wait_autojoy() {
    while HVBJOY & 0x01 != 0 {}
}

// Sync main loop to NMI frame counter with drop-frame tolerance.
// If the counter has not advanced past last_frame, WAI sleeps until NMI fires.
// If one or more NMIs already fired during main work, falls through immediately
// (no extra-frame penalty) and resyncs last_frame to the current count.
//
// Requires: frame_count is incremented by the NMI handler; last_frame is a
// mutable integer owned by main code (persist across calls, do not touch from NMI).
//
// Usage:
//   wait_vblank_sync!(FRAME_COUNTER, LAST_FRAME);
macro_rules! wait_vblank_sync($frame_count:ident, $last_frame:ident) {
    if $frame_count == $last_frame {
        wait_nmi!();
    }
    $last_frame = $frame_count;
}


// Clear VRAM (fill with zeros) - slow but thorough
fn clear_vram() {
    VMADDL = 0;
    VMADDH = 0;
    VMAIN = VmainTrigger::High;

    // 128 * 256 = 32768 words to clear
    for i in 0..32768 {
        VMDATAL = 0;
        VMDATAH = 0;
    }
}

// Clear CGRAM (all colors to black)
fn clear_cgram() {
    CGADD = 0;
    // 256 colors * 2 bytes each = 512 bytes
    for i in 0..512 {
        CGDATA = 0;
    }
}

// Clear OAM (all sprites off-screen)
fn clear_oam() {
    OAMADDL = 0;
    OAMADDH = 0;

    for i in 0..128 {
        OAMDATA = 0;
        OAMDATA = 240;  // Y off-screen
        OAMDATA = 0;
        OAMDATA = 0;
    }

    // Extended table
    for j in 0..32 {
        OAMDATA = 0;
    }
}

// Initialize PPU registers to safe defaults
fn init_ppu() {
    INIDISP = FORCE_BLANK;
    OBSEL = 0;
    OAMADDL = 0;
    OAMADDH = 0;
    BGMODE = 0;
    MOSAIC = 0;
    BG1SC = 0;
    BG2SC = 0;
    BG3SC = 0;
    BG4SC = 0;
    BG12NBA = 0;
    BG34NBA = 0;

    // BG scroll registers (write-twice each)
    let mut ptr: *u8 = 0x210D as *u8;
    for i in 0..16 {
        ptr[i] = 0;
    }

    VMAIN = VmainTrigger::High;
    VMADDL = 0;
    VMADDH = 0;

    // Mode 7: identity matrix
    M7SEL = 0;
    M7A = 1; M7A = 0;
    M7B = 0; M7B = 0;
    M7C = 0; M7C = 0;
    M7D = 1; M7D = 0;
    M7X = 0; M7X = 0;
    M7Y = 0; M7Y = 0;

    CGADD = 0;
    W12SEL = 0;
    W34SEL = 0;
    WOBJSEL = 0;
    WH0 = 0;
    WH1 = 0;
    WH2 = 0;
    WH3 = 0;
    WBGLOG = 0;
    WOBJLOG = 0;
    TM = 0;
    TS = 0;
    TMW = 0;
    TSW = 0;
    CGWSEL = 0;
    CGADSUB = 0;
    COLDATA = ColorChannel::Red;
    COLDATA = ColorChannel::Green;
    COLDATA = ColorChannel::Blue;
    SETINI = 0;
}

// Initialize CPU registers
fn init_cpu() {
    NMITIMEN = 0;
    HDMAEN = 0;
    MEMSEL = 1;
}

// Full SNES initialization
fn snes_init() {
    init_cpu();
    init_ppu();
    clear_vram();
    clear_cgram();
    clear_oam();
    NMITIMEN = Interrupt::Nmi | Interrupt::AutoJoy;
}

// Delay for specified number of frames
// Usage: delay(60);  // Wait ~1 second (NTSC)
far fn delay(frames: u16) {
    let mut count: u16 = frames;
    loop {
        wait_nmi!();
        count--;
        if count == 0 {
            break;
        }
    }
}

// Check if console is PAL (returns 1) or NTSC (returns 0)
// Usage: if is_pal() { ... }
fn is_pal() -> bool {
    A = STAT78 & 0x10;
    return !STATUS.Zero;
}

// Set pixelization/mosaic effect (user-friendly version)
// level: 0 = off, 1 = min pixelization, 16 = max pixelization
// bgs: which backgrounds to apply mosaic to (use Screen::BG1, etc.)
// Usage: set_pixelize(4, Screen::BG1 | Screen::BG2);
far fn set_pixelize(level: u8, bgs: u16) {
    if level == 0 {
        MOSAIC = 0;
    } else {
        let mut val: u8 = level;
        val = val << 4;
        val = val | (bgs as u8);
        MOSAIC = val;
    }
}

// ============================================================================
// SPC700 TRANSFER FUNCTIONS
// ============================================================================

// Wait for SPC700 to be ready
fn spc_wait_ready() -> u8 {
    let mut timeout: u8 = 0;
    loop {
        A = APUIO0;
        if A == 0xAA {
            A = APUIO1;
            if A == 0xBB {
                A = 1;
                return A;
            }
        }
        timeout++;
        if timeout == 0 {
            A = 0;
            return A;
        }
    }
}

// Begin SPC700 transfer to destination address
fn spc_begin_transfer(dest_low @ A: u8, dest_high: u16) {
    APUIO2 = dest_low;
    APUIO3 = dest_high;
    APUIO1 = 0x01;
    APUIO0 = 0xCC;

    loop {
        A = APUIO0;
        if A == 0xCC {
            break;
        }
    }
}

// Transfer byte to SPC700
fn spc_transfer_byte(data @ A: u8, index: u16) {
    APUIO1 = data;
    APUIO0 = index;

    loop {
        A = APUIO0;
        if A == index {
            break;
        }
    }
}

// End SPC700 transfer and start execution
fn spc_end_transfer(exec_low @ A: u8, exec_high: u16) {
    APUIO2 = exec_low;
    APUIO3 = exec_high;

    A = APUIO0;
    A = A + 2;
    A = A & 0xFE;
    APUIO1 = 0;
    APUIO0 = A;
}


// ============================================================================
// FAST DMA CLEAR FUNCTIONS
// ============================================================================

// DMA clear VRAM (clears all 64KB)
// Requires a zero byte somewhere in ROM/RAM for the fill value
// Usage: dma_clear_vram!(0, zero_byte_ptr);
macro_rules! dma_clear_vram($channel:literal, $zero_ptr:expr) {
    VMADD = 0;
    VMAIN = VmainTrigger::High;
    dma_set_src!($channel, $zero_ptr);
    asm!("STZ DAS{CH}", CH=$channel);  // 0 = 64KB
    dma_set_ppu_dest!($channel, 9, 24);  // 9 = DMA_MODE_2REG_1WRITE | DMA_FIXED, 24 = $18
    dma_trigger!($channel);
}

// DMA clear CGRAM (clears all 512 bytes)
// Usage: dma_clear_cgram!(0, zero_ptr);
macro_rules! dma_clear_cgram($channel:literal, $zero_ptr:expr) {
    CGADD = 0;
    dma_set_src!($channel, $zero_ptr);
    dma_set_size!($channel, 512);
    dma_set_ppu_dest!($channel, 10, 34);  // 10 = DMA_MODE_1REG_2WRITE | DMA_FIXED, 34 = $22
    dma_trigger!($channel);
}

